# Required: 64-char hex string (32 bytes) for AES-256-GCM credential encryption
# Generate with: openssl rand -hex 32
HITL_CRED_KEY=your-64-char-hex-key-here

# Required: password for the Web UI (HTTP Basic Auth, username: admin)
HITL_ADMIN_PASSWORD=your-admin-password-here

# Optional: base URL of an OpenAI-compatible embedding API (enables vector search)
# Ollama example: http://localhost:11434
# OpenAI example: https://api.openai.com
OPENAI_BASE_URL=

# Optional: API key for the embedding API (not required for Ollama)
OPENAI_API_KEY=
