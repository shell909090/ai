{
  "scripts": {
    "build": "mkdir -p dist && esbuild src/app.ts --bundle --format=iife --outfile=dist/app.js --target=es2020 && cp index.html style.css dist/",
    "lint": "eslint 'src/**/*.ts' && tsc --noEmit",
    "fmt": "prettier --write 'src/**/*.ts'",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "happy-dom": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
